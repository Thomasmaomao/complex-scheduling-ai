# ============================================
# 后端 API - 环境变量配置示例
# ============================================

# 数据库配置
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/car_insurance

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379

# API 配置
API_HOST=0.0.0.0
API_PORT=8001
DEBUG=false

# JWT 配置（生产环境请修改）
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
